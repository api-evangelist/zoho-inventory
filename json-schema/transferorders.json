            "type": "number",
            "format": "float",
            "example": 1
          },
          "storage_out_id": {
            "description": "Unique identifier of the storage record. Applicable only when updating the transfer order.",
            "type": "string",
            "example": "6780203000001106135"
          },
          "serial_numbers": {
            "description": "Serial numbers transferred from this bin.",
            "type": "array",
