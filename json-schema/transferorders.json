    "customfield_id": {
      "type": "string",
      "description": "Unique ID of the custom field."
    },
    "label": {
      "description": "Label of the Custom Field",
      "type": "string"
    },
    "value": {
      "description": "Value of the Custom Field",
      "type": "string"
    },
    "custom_fields": {
