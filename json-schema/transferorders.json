        },
        "from_warehouse_id": {
          "description": "Source warehouse ID when multi-warehouse is enabled.",
          "type": "string",
          "example": "460000000038075"
        },
        "to_warehouse_id": {
          "description": "Destination warehouse ID when multi-warehouse is enabled.",
          "type": "string",
