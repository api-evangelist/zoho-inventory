            "type": "string",
            "example": "6780203000000206981"
          },
          "in_quantity": {
            "description": "Inward quantity into the bin.",
            "type": "number",
            "format": "float",
            "example": 1
          },
          "storage_in_id": {
            "description": "Unique identifier of the storage record. Applicable only when updating the transfer order.",
            "type": "string",
