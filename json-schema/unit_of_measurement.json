                "example": 4815000000044352
              },
              "base_unit_name": {
                "description": "Name of the base unit.",
                "type": "string",
                "example": "kilogram"
              },
              "base_unit": {
                "description": "Short code of the base unit.",
                "type": "string",
                "example": "kg"
              },
              "unit_conversion_count": {
