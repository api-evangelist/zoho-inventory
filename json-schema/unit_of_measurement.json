            "type": "object",
            "properties": {
              "unit_conversion_id": {
                "description": "Unique ID of the unit conversion. Required when updating an existing conversion.",
                "type": "string",
                "example": 4815000000044354
              },
              "target_unit_id": {
                "description": "Unique ID of the target unit.",
                "type": "string",
                "example": 4815000000044356
              },
